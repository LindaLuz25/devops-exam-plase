pipeline {
    agent any

    environment {
        ACTIVE_FILE = "active_env.txt"
    }

    stages {
        stage('Pre-Build Clean') {
            steps {
                // Esto borra cualquier contenedor huérfano antes de empezar
                sh "docker compose -f app/docker-compose.yml down --remove-orphans || true"
            }
        }
        
        stage('Verificar') {
            steps {
                sh 'ls -l app/nginx/nginx.conf'
            }
        }

        stage('Detect Active') {
            steps {
                script {
                    def activeVal = fileExists(ACTIVE_FILE) ? readFile(ACTIVE_FILE).trim() : "blue"
                    def inactiveVal = (activeVal == "blue") ? "green" : "blue"

                    env.ACTIVE = activeVal
                    env.INACTIVE = inactiveVal
                }
            }
        }

        stage('Deploy App') {
            steps {
                script {
                    echo "Desplegando en: ${env.INACTIVE}"
                    // Intentamos levantar el contenedor. Si falla, el post { failure } se encargará
                    sh "docker compose -f app/docker-compose.yml up -d app-${env.INACTIVE}"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    def targetUrl = "http://app-${env.INACTIVE}:3000/health"
                    sleep 10 
                    
                    def status = sh(
                        script: "curl -s -o /dev/null -w '%{http_code}' ${targetUrl}",
                        returnStdout: true
                    ).trim()

                    if (status != "200") {
                        // Al lanzar 'error', Jenkins detiene el pipeline y salta directo al post { failure }
                        error("Health check falló: ${status}")
                    }
                }
            }
        }

        stage('Clean and Prepare') {
            steps {
                script {
                    echo "🧹 Limpiando residuos de Docker y preparando configuraciones..."
                    
                    // 1. Eliminar contenedores antiguos que puedan estar bloqueando los montajes
                    sh "docker rm -f nginx prometheus grafana || true"
                    
                    // 2. Forzar la eliminación de carpetas erróneas (si existen)
                    sh "sudo rm -rf app/nginx/nginx.conf"
                    sh "sudo rm -rf app/monitoring/prometheus.yml"
                    
                    // 3. Crear archivos planos (esto garantiza que sean archivos y no directorios)
                    sh "touch app/nginx/nginx.conf"
                    sh "touch app/monitoring/prometheus.yml"
                    
                    // 4. Inyectar contenido real (Usamos 'cat' para escribir el archivo)
                    // Esto evita depender de que el archivo exista previamente en el FS del host
                    sh '''
                            cat <<EOF > app/nginx/nginx.conf
                        events { worker_connections 1024; }
                        http {
                            upstream app {
                                server app-blue:3000;
                                server app-green:3000;
                            }
                            server {
                                listen 80;
                                location / {
                                    proxy_pass http://app;
                                }
                            }
                        }
                        EOF
                                                cat <<EOF > app/monitoring/prometheus.yml
                        global:
                        scrape_interval: 5s
                        scrape_configs:
                        - job_name: 'node-app'
                            static_configs:
                            - targets: ['app-blue:3000', 'app-green:3000']
                        EOF
                    '''
                    echo "✅ Entorno preparado exitosamente."
                }
            }
        }

        stage('Start Infrastructure') {
            steps {
                script {
                    // Solo levantamos nginx/monitoreo si la app está saludable
                    sh "docker compose -f app/docker-compose.yml up -d nginx prometheus grafana"
                }
            }
        }

        stage('Switch Traffic') {
            steps {
                script {
                    sh """
                        sed 's/app-${env.ACTIVE}/app-${env.INACTIVE}/g' app/nginx/nginx.conf > app/nginx/nginx.conf.tmp
                        mv app/nginx/nginx.conf.tmp app/nginx/nginx.conf
                        docker compose -f app/docker-compose.yml restart nginx
                    """
                    writeFile file: ACTIVE_FILE, text: env.INACTIVE
                    echo "Tráfico cambiado exitosamente a ${env.INACTIVE}"
                }
            }
        }
    }

    post {
        failure {
            script {
                echo "🚨 ERROR DETECTADO: Limpiando contenedores fallidos para evitar conflictos..."
                
                // Borramos el contenedor de la aplicación que falló (INACTIVE)
                // 'rm -f' detiene y elimina el contenedor en un solo paso
                sh "docker compose -f app/docker-compose.yml rm -f -s app-${env.INACTIVE} || true"
                
                // También es buena idea limpiar el activo si sospechas que el error es global
                // sh "docker compose -f app/docker-compose.yml rm -f -s app-${env.ACTIVE} || true"

                echo "♻️ Sistema purgado. El próximo build encontrará un entorno limpio."
            }
        }
        success {
            echo "✅ Despliegue exitoso."
            // Opcional: Si quieres borrar el contenedor de la versión anterior para ahorrar RAM:
            // sh "docker compose -f app/docker-compose.yml rm -f -s app-${env.ACTIVE} || true"
        }
    }
}