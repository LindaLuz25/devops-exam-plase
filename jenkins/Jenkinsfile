pipeline {
    agent any

    environment {
        ACTIVE_FILE = "active_env.txt"
    }

    stages {

        stage('Detect Active') {
            steps {
                script {
                    if (fileExists(ACTIVE_FILE)) {
                        ACTIVE = readFile(ACTIVE_FILE).trim()
                    } else {
                        ACTIVE = "blue"
                    }

                    INACTIVE = (ACTIVE == "blue") ? "green" : "blue"

                    env.ACTIVE = ACTIVE
                    env.INACTIVE = INACTIVE
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    // Levantamos el contenedor inactivo sin mapear puertos al host (innecesario)
                    sh "docker compose -f app/docker-compose.yml up -d app-${env.INACTIVE}"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    // IMPORTANTE: Usamos el nombre del servicio (app-blue/green) en lugar de localhost
                    // Jenkins puede resolver los nombres de servicio si están en la misma red
                    def targetUrl = "http://app-${env.INACTIVE}:3000/health"
                    echo "Verificando salud en: ${targetUrl}"
                    
                    // Espera de cortesía para que Node.js inicie
                    sleep 10 
                    
                    def status = sh(
                        script: "curl -s -o /dev/null -w '%{http_code}' ${targetUrl}",
                        returnStdout: true
                    ).trim()

                    if (status != "200") {
                        error("Health check failed con código: ${status}")
                    }
                }
            }
        }

        stage('Start Infra App (nginx + monitoring)') {
            steps {
                script {
                    // Usa una ruta absoluta basada en la variable de entorno de Jenkins
                    def composeFile = "${WORKSPACE}/app/docker-compose.yml"
                    sh "docker compose -f ${composeFile} up -d nginx prometheus grafana"
                }
            }
        }

        stage('Switch Traffic') {
            steps {
                script {
                    echo "Cambiando tráfico de ${env.ACTIVE} a ${env.INACTIVE}"
                    
                    // Usamos un archivo temporal para generar el nuevo nginx.conf
                    // Esto evita que el 'sed' corrompa el archivo original con cada ejecución
                    sh """
                        sed 's/app-${env.ACTIVE}/app-${env.INACTIVE}/g' app/nginx/nginx.conf > app/nginx/nginx.conf.tmp
                        mv app/nginx/nginx.conf.tmp app/nginx/nginx.conf
                        docker compose -f app/docker-compose.yml restart nginx
                    """

                    // Guardar estado
                    writeFile file: ACTIVE_FILE, text: env.INACTIVE
                    
                    // Opcional: Detener el contenedor antiguo para ahorrar recursos
                    sh "docker compose -f app/docker-compose.yml stop app-${env.ACTIVE}"
                }
            }
        }
    }
    
    post {
        success {
            echo "Despliegue exitoso. Limpiando entorno..."
            // Opcional: Podrías eliminar el contenedor antiguo en lugar de solo detenerlo
            // sh "docker compose -f app/docker-compose.yml rm -f app-${env.ACTIVE}"
        }
        failure {
            script {
                echo "Error detectado. Limpiando contenedor fallido: ${env.INACTIVE}"
                sh "docker compose -f app/docker-compose.yml stop app-${env.INACTIVE} || true"
                sh "docker compose -f app/docker-compose.yml rm -f app-${env.INACTIVE} || true"
            }
        }
    }
}