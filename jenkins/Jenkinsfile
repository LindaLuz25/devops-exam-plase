pipeline {
    agent any

    environment {
        ACTIVE_FILE = "active_env.txt"
        COMPOSE_FILE = "app/docker-compose.yml"
        NETWORK = "devops-net"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Init Network') {
            steps {
                sh """
                echo "🌐 Verificando red..."

                docker network inspect ${NETWORK} >/dev/null 2>&1 || \
                docker network create ${NETWORK}

                docker network ls | grep ${NETWORK}
                """
            }
        }

        stage('Pre-Build Clean') {
            steps {
                sh """
                echo "🧹 Limpieza controlada..."

                docker compose -f ${COMPOSE_FILE} down -v --remove-orphans || true

                docker rm -f prometheus-final nginx-final grafana app-blue app-green || true
                """
            }
        }

        stage('Detect Active') {
            steps {
                script {
                    def activeVal = fileExists(ACTIVE_FILE) ? readFile(ACTIVE_FILE).trim() : "blue"
                    def inactiveVal = (activeVal == "blue") ? "green" : "blue"

                    env.ACTIVE = activeVal
                    env.INACTIVE = inactiveVal

                    echo "Activo: ${env.ACTIVE}"
                    echo "Nuevo despliegue: ${env.INACTIVE}"
                }
            }
        }

        stage('Debug Workspace') {
            steps {
                sh """
                echo "📂 WORKSPACE:"
                pwd

                echo "📁 CONTENIDO COMPLETO:"
                ls -R .

                echo "📁 APP:"
                ls -R app || true

                echo "📁 MONITORING:"
                ls -R app/monitoring || true
                """
            }
        }

        stage('Final Debug') {
            steps {
                sh """
                echo "📁 FULL REPO STRUCTURE:"
                ls -R .

                echo "📁 APP FOLDER:"
                ls -R app || true

                echo "📁 MONITORING FOLDER:"
                ls -R app/monitoring || true

                echo "📁 SEARCH PROMETHEUS:"
                find . -name "prometheus.yml"
                """
            }
        }
        stage('Verify Git Content') {
            steps {
                sh """
                echo "📌 GIT INFO:"
                git branch || true
                git remote -v || true

                echo "📌 GIT LS TREE:"
                git ls-tree -r HEAD --name-only || true
                """
            }
        }


        stage('Validate Files') {
            steps {
                sh """
                echo "🔍 Validando archivos críticos..."

                # Prometheus
                if [ ! -f app/monitoring/prometheus.yml ]; then
                  echo "❌ prometheus.yml no existe"
                  exit 1
                fi

                # Validar que NO sea directorio
                if [ -d app/monitoring/prometheus.yml ]; then
                  echo "❌ prometheus.yml es una carpeta"
                  exit 1
                fi

                chmod 644 app/monitoring/prometheus.yml

                # Nginx template
                if [ ! -f app/nginx/nginx.template.conf ]; then
                  echo "❌ nginx.template.conf no existe"
                  exit 1
                fi
                """
            }
        }


        stage('Deploy App') {
            steps {
                script {
                    echo "🚀 Desplegando app-${env.INACTIVE}..."
                    sh "docker compose -f ${COMPOSE_FILE} up -d app-${env.INACTIVE}"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    def url = "http://app-${env.INACTIVE}:3000/health"

                    echo "⏳ Esperando a que la app responda..."

                    def retries = 10
                    def status = "000"

                    for (int i = 0; i < retries; i++) {
                        sleep 5
                        status = sh(
                            script: "curl -s -o /dev/null -w '%{http_code}' ${url} || true",
                            returnStdout: true
                        ).trim()

                        echo "Intento ${i+1}: ${status}"

                        if (status == "200") {
                            break
                        }
                    }

                    if (status != "200") {
                        error("❌ Health check falló")
                    }
                }
            }
        }

        stage('Start Infrastructure') {
            steps {
                sh """
                echo "📊 Levantando infraestructura..."

                docker compose -f ${COMPOSE_FILE} up -d nginx prometheus grafana \
                --force-recreate --remove-orphans --no-deps
                """
            }
        }

        stage('Switch Traffic') {
            steps {
                script {
                    echo "🔁 Cambiando tráfico..."

                    sh """
                    sed "s/ENV/${INACTIVE}/g" app/nginx/nginx.template.conf > app/nginx/nginx.conf

                    docker cp app/nginx/nginx.conf nginx-final:/etc/nginx/nginx.conf

                    docker restart nginx-final
                    """

                    writeFile file: ACTIVE_FILE, text: env.INACTIVE

                    echo "✅ Tráfico ahora en ${env.INACTIVE}"
                }
            }
        }
    }

    post {

        failure {
            script {
                echo "🚨 Rollback..."

                sh """
                docker compose -f ${COMPOSE_FILE} down -v --remove-orphans || true
                docker rm -f prometheus-final nginx-final grafana app-blue app-green || true
                """

                echo "♻️ Sistema limpio"
            }
        }

        success {
            echo "🎉 Deploy exitoso!"
        }
    }
}